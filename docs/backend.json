
{
    "entities": {
        "User": {
            "title": "User",
            "description": "Represents a user of the application.",
            "type": "object",
            "properties": {
                "uid": { "type": "string" },
                "email": { "type": "string", "format": "email" },
                "name": { "type": "string" },
                "role": { "type": "string", "enum": ["user", "admin"] },
                "fcmTokens": {
                    "type": "array",
                    "description": "An array of Firebase Cloud Messaging (FCM) tokens for sending push notifications to the user's devices.",
                    "items": {
                        "type": "string"
                    }
                }
            },
            "required": ["uid", "email", "name", "role"]
        },
        "UserMedia": {
            "title": "User Media",
            "description": "Media generated or uploaded by a user.",
            "type": "object",
            "properties": {
                "userId": { "type": "string", "description": "The UID of the user who owns the media." },
                "type": { "type": "string", "enum": ["ai-generated", "community-chat", "ticket-media"] },
                "mediaUrl": { "type": "string", "format": "uri" },
                "prompt": { "type": "string", "description": "The prompt used to generate the media, if applicable." },
                "createdAt": { "type": "string", "format": "date-time" },
                "expiresAt": { "type": "string", "format": "date-time" }
            },
            "required": ["userId", "type", "mediaUrl", "createdAt", "expiresAt"]
        },
        "ShortenedURL": {
            "title": "Shortened URL",
            "description": "Represents a shortened URL mapping.",
            "type": "object",
            "properties": {
                "originalUrl": {
                    "type": "string",
                    "format": "uri",
                    "description": "The original, long URL."
                },
                "shortId": {
                    "type": "string",
                    "description": "The unique short identifier for the URL."
                },
                "createdAt": {
                    "type": "string",
                    "format": "date-time",
                    "description": "The timestamp when the short URL was created."
                }
            },
            "required": ["originalUrl", "shortId", "createdAt"]
        }
    },
    "auth": {
        "providers": ["anonymous", "google.com"]
    },
    "firestore": {
        "/users/{userId}": {
            "schema": { "$ref": "#/entities/User" },
            "description": "Stores public user profile information."
        },
        "/userMedia/{mediaId}": {
            "schema": { "$ref": "#/entities/UserMedia" },
            "description": "Stores media files associated with a user."
        },
        "/shortenedUrls/{shortId}": {
            "schema": { "$ref": "#/entities/ShortenedURL" },
            "description": "Stores the mapping between short URL IDs and original URLs."
        }
    }
}
