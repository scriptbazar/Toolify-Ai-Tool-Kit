
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Public user data, anyone can read
    match /users/{userId} {
      allow read: if true;
      // Only the authenticated user can write to their own document
      allow write: if isOwner(userId);
    }
    
    // User media can only be read by the owner
    match /userMedia/{mediaId} {
      allow read, delete: if isOwner(resource.data.userId);
      allow create: if request.auth != null;
    }
    
    // Community chat messages
    match /communityChat/{messageId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
    }
  }
}
