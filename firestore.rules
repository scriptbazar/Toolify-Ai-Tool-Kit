
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // GENERAL PUBLIC READ RULES
    // Anyone can read tools, blog posts, and main settings
    match /tools/{toolId} {
      allow read: if true;
      allow write: if false; // Should be managed from Admin SDK
    }
    match /blogPosts/{postId} {
      allow read: if true;
      allow write: if false; // Should be managed from Admin SDK
    }
    match /blogCategories/{categoryId} {
        allow read: if true;
        allow write: if false; // Should be managed from Admin SDK
    }
    match /settings/main {
      allow read: if true;
      allow write: if false; // Should be managed from Admin SDK
    }
    match /announcements/{announcementId} {
        allow read: if true;
        allow write: if false; // Should be managed from Admin SDK
    }


    // USER-SPECIFIC RULES
    match /users/{userId} {
      // A user can read and update their own document
      allow read, update: if isUser(userId);
      // Only admin can create or delete users via server-side logic, not client
      allow create, delete: if false; 
      
      // Subcollections for a user
      match /activity/{activityId} {
        allow read, write: if isUser(userId);
      }
      match /loginHistory/{historyId} {
        allow read, write: if isUser(userId);
      }
    }
    
    // REVIEWS
    match /reviews/{reviewId} {
        // Anyone can read approved reviews
        allow read: if resource.data.status == 'approved' || isSignedIn();
        // Only signed-in users can create reviews
        allow create: if isSignedIn();
        // Only the user who wrote the review can update/delete it (or an admin)
        allow update, delete: if isUser(resource.data.authorId);
    }

    // TICKETS & MEDIA
    match /tickets/{ticketId} {
        allow read, write: if isUser(resource.data.userId);
        allow create: if isSignedIn();
    }
    match /userMedia/{mediaId} {
        allow read, write: if isUser(resource.data.userId);
        allow create: if isSignedIn();
    }
    
    // COMMUNITY CHAT
    match /communityChat/{messageId} {
        // Any signed-in user can read and write to the community chat
        allow read, write: if isSignedIn();
    }
    
    // LEADS & TOOL REQUESTS (write-only for users)
    match /leads/{leadId} {
        allow create: if true;
        allow read, update, delete: if false;
    }
     match /toolRequests/{requestId} {
        allow create: if isSignedIn();
        allow read, update, delete: if false;
    }

  }
}
