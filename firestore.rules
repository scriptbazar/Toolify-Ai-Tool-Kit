
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Allow users to read and write to their own document
    match /users/{userId} {
      allow read, update, write: if request.auth != null && request.auth.uid == userId;
    }

    // Tools collection should be readable by anyone, but only writable by admins (not yet implemented)
    // For now, allow public read access so the favorites page can get tool details.
    match /tools/{toolId} {
      allow read: if true;
      allow write: if false; // Protect the tools collection from client-side writes
    }
    
    // Default deny all other collections for security
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
