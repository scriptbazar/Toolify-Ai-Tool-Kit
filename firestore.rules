
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Allow anyone to read public collections
    match /tools/{toolId} {
      allow read: if true;
    }
    match /settings/{settingId} {
        allow read: if true;
    }
     match /comments/{commentId} {
        allow read: if true;
    }
    match /announcements/{announcementId} {
      allow read: if true;
    }

    // Allow anyone to submit leads and tickets
    match /leads/{leadId} {
        allow create: if true;
    }
    match /tickets/{ticketId} {
        allow create: if true;
    }
    
    // Logged-in users can manage their own data
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      // Allow users to create their own document on signup
      allow create: if request.auth != null && request.auth.uid == userId;
      // Allow users to update their own profile, but not change their role
      allow update: if request.auth != null && request.auth.uid == userId && !('role' in request.resource.data);
    }

    // Users can read and update their own tickets
     match /tickets/{ticketId} {
      allow read, update: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Community Chat Rules
    match /communityChat/{messageId} {
      // Any logged-in user can read all chat messages
      allow read: if request.auth != null;

      // Any logged-in user can create a message, but only as themselves
      allow create: if request.auth != null && request.auth.uid == request.resource.data.fromId;

      // No one can update or delete chat messages to preserve history
      allow update, delete: if false;
    }

    // Default deny: For any other collection not specified, deny all access.
    // This is safer than a broad allow rule. Admin access is handled by Admin SDK and is not affected by these rules.
  }
}
