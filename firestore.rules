rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // WARNING: These rules are insecure and are meant for development only.
    // They allow any authenticated user to read and write to the entire database.
    // Before deploying to production, you should write more specific rules
    // to secure your data.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
