rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      // Allow creating users (for signup)
      allow create: if true;
      
      // Allow users to read their own full document
      allow read: if request.auth.uid == userId;

      // Allow any authenticated user to read just the role field
      allow get: if request.auth != null && resource.data.keys().hasOnly(['role']);

      // Allow users to update their own data
      allow update: if request.auth.uid == userId;
      
      // Prevent users from deleting their own account from the database
      allow delete: if false;

      // Allow admins to read the full user list
      match /users/{document=**} {
        allow read: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      }
    }
  }
}
